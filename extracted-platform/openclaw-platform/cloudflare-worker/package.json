    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "agents": "^0.0.62",
    "@cloudflare/ai-chat": "latest",
    "workers-ai-provider": "^1.0.0",
    "ai": "^4.3.16",
    "hono": "^4.7.0",
    "stripe": "^17.7.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260324.0",
    "typescript": "~5.9.0",
    "wrangler": "^4.19.0"
  }
}

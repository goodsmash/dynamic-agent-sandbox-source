{
  "name": "openclaw-platform",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --remote",
    "dev:local": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create openclaw_users",
    "d1:migrate": "wrangler d1 migrations apply openclaw_users --remote",

{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd .. && npm run start-api",
    "dev-nix": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "dev-win": "set NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "start-windows": "set NODE_ENV=development && node --enable-source-maps ./dist/index.mjs",
    "start-nix": "NODE_ENV=development node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "openai": "^6.32.0",
    "pg": "^8.14.1",
    "ws": "^8.18.0",
    "@anthropic-ai/sdk": "^0.80.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*"
  },
  "devDependencies": {
    "@workspace/api-spec": "workspace:*",
    "@types/pg": "^8.11.6"
  }
}